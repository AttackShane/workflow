{
    "compilerOptions": {
        "checkJs": true,
        "noEmit": true,
        "skipLibCheck": true,
        "strict": false,
        "maxNodeModuleJsDepth": 0,
        "types": ["node"],
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        "*.cjs"
    ]
}